<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Soulbound.AppShellAuth"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Soulbound.Views"
    Shell.FlyoutBehavior="Flyout"
    FlowDirection="RightToLeft">

    <ShellContent
        Title="Pet Selection"
        ContentTemplate="{DataTemplate local:PetSelectionPage}"
        Route="PetSelectionPage" />

    <ShellContent
        Title="Main Room"
        ContentTemplate="{DataTemplate local:MainRoomPage}"
        Route="MainRoomPage" />

    <ShellContent
        Title="Create Goal"
        ContentTemplate="{DataTemplate local:CreateGoalPage}"
        Route="CreateGoalPage" />

    <ShellContent
        Title="Goal History"
        ContentTemplate="{DataTemplate local:GoalHistoryPage}"
        Route="GoalHistoryPage" />

    <ShellContent
    Title="Statistics"
    ContentTemplate="{DataTemplate local:StatisticsPage}"
    Route="StatisticsPage" />

    <ShellContent
        Title="Schedule"
        ContentTemplate="{DataTemplate local:SchedulePage}"
        Route="SchedulePage" />

    <MenuItem Clicked="MenuItem_Logout_Clicked" Text="Logout" />
</Shell>
