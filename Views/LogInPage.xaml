<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Soulbound.Views.LogInPage"
             Title="LogInPage">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource AppBackgroundTop}" Offset="0.0" />
                <GradientStop Color="{StaticResource AppBackgroundBottom}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <VerticalStackLayout Padding="24" Spacing="14" VerticalOptions="Center" HorizontalOptions="Center">
            <Frame Padding="24" MaximumWidthRequest="560" HorizontalOptions="Center">
                <VerticalStackLayout Spacing="12">
                    <Label Text="WELCOME BACK"
                           FontSize="30"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />

                    <Label Text="{Binding MessageForUser}"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource CardMutedText}" />

                    <Label Text="Email" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0" Text="{Binding UserInput}" Placeholder="Enter your email..." />
                        <Button Grid.Column="1"
                                Text="✕"
                                WidthRequest="36"
                                HeightRequest="36"
                                CornerRadius="18"
                                Padding="0"
                                Command="{Binding ResetUsernameCommand}" />
                    </Grid>

                    <Label Text="Password" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0"
                               Text="{Binding UserPassword}"
                               Placeholder="Enter your password..."
                               IsPassword="True" />
                        <Button Grid.Column="1"
                                Text="✕"
                                WidthRequest="36"
                                HeightRequest="36"
                                CornerRadius="18"
                                Padding="0"
                                Command="{Binding ResetPasswordCommand}" />
                    </Grid>

                    <Button Text="Log In"
                            IsEnabled="{Binding IsLoginEnable}"
                            Command="{Binding TryLoginCommand}" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="Go to Registration"
                    Command="{Binding GotoRegisterPageCommand}" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>