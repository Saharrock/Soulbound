<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Soulbound.Views.WelcomePage"
             Title="WelcomePage">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource AppBackgroundTop}" Offset="0.0" />
                <GradientStop Color="{StaticResource AppBackgroundBottom}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <VerticalStackLayout Padding="24" Spacing="24" VerticalOptions="Center" HorizontalOptions="Center">
            <Frame Padding="24" MaximumWidthRequest="460">
                <VerticalStackLayout Spacing="16">
                    <Label Text="SOULBOUND"
                           FontSize="40"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Grow, reflect, and train your SoulMate every day."
                           TextColor="{StaticResource CardMutedText}"
                           HorizontalTextAlignment="Center"/>
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Button Text="Log In"
                                WidthRequest="140"
                                Command="{Binding GoToLoginCommand}" />
                        <Button Text="Registration"
                                WidthRequest="160"
                                Command="{Binding GoToRegistrationCommand}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </Grid>
</ContentPage>