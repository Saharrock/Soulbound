<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Soulbound.Views.CreateGoalPage"
             x:Name="CreateGoalRoot"
             Title="CreateGoalPage">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource AppBackgroundTop}" Offset="0.0" />
                <GradientStop Color="{StaticResource AppBackgroundBottom}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>
        <ScrollView>
            <VerticalStackLayout HorizontalOptions="Center" Padding="20" Spacing="16">
                <Frame MaximumWidthRequest="460" Padding="24">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Create New Goal" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Entry Placeholder="Title" Text="{Binding NewTitle}" />
                        <Entry Placeholder="Description" Text="{Binding NewDescription}" />
                        <DatePicker Date="{Binding SelectedDate}" MinimumDate="{Binding TodayDate}" MaximumDate="2035-12-31"/>

                        <Label Text="Goal type" FontAttributes="Bold" Margin="0,10,0,0"/>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="18">
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <CheckBox IsChecked="{Binding NewIsPhysical}" Color="{StaticResource PhysicalAccent}" />
                                <Label Text="Physical" FontSize="12" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <CheckBox IsChecked="{Binding NewIsIntellectual}" Color="{StaticResource IntellectualAccent}" />
                                <Label Text="Intellectual" FontSize="12" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <CheckBox IsChecked="{Binding NewIsMental}" Color="{StaticResource MentalAccent}" />
                                <Label Text="Mental" FontSize="12" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <Label Text="Training days" FontAttributes="Bold" Margin="0,8,0,0"/>
                        <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4"><CheckBox IsChecked="{Binding IsMonday}" /><Label Text="Mon" VerticalOptions="Center"/></HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4"><CheckBox IsChecked="{Binding IsTuesday}" /><Label Text="Tue" VerticalOptions="Center"/></HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="2" Spacing="4"><CheckBox IsChecked="{Binding IsWednesday}" /><Label Text="Wed" VerticalOptions="Center"/></HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="3" Spacing="4"><CheckBox IsChecked="{Binding IsThursday}" /><Label Text="Thu" VerticalOptions="Center"/></HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4"><CheckBox IsChecked="{Binding IsFriday}" /><Label Text="Fri" VerticalOptions="Center"/></HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4"><CheckBox IsChecked="{Binding IsSaturday}" /><Label Text="Sat" VerticalOptions="Center"/></HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="2" Spacing="4"><CheckBox IsChecked="{Binding IsSunday}" /><Label Text="Sun" VerticalOptions="Center"/></HorizontalStackLayout>
                        </Grid>

                        <Label Text="{Binding MessageForUser}" FontSize="14" TextColor="#FFE3B4" HorizontalOptions="Center"/>
                        <Button Text="Add Goal" Command="{Binding AddGoalCommand}" BackgroundColor="{StaticResource SuccessAccent}" WidthRequest="180" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame MaximumWidthRequest="460" Padding="24">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Quick starts" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <CollectionView ItemsSource="{Binding QuickPacks}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame BackgroundColor="{StaticResource CardBackgroundDark}" Padding="12" Margin="0,0,0,10">
                                        <VerticalStackLayout Spacing="8">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="18" />
                                            <Label Text="{Binding Description}" TextColor="{StaticResource CardMutedText}" />
                                            <Button Text="{Binding PreviewButtonText}"
                                                    Command="{Binding Source={x:Reference CreateGoalRoot}, Path=BindingContext.TogglePackPreviewCommand}"
                                                    CommandParameter="{Binding .}" />

                                            <VerticalStackLayout IsVisible="{Binding IsExpanded}" Spacing="6">
                                                <Label Text="Tasks in this pack" FontAttributes="Bold" />
                                                <CollectionView ItemsSource="{Binding Tasks}" SelectionMode="None">
                                                    <CollectionView.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                                                <Label Text="{Binding Title}" />
                                                                <Label Grid.Column="1" Text="{Binding XpText}" TextColor="{StaticResource CardMutedText}" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </CollectionView.ItemTemplate>
                                                </CollectionView>
                                                <Label Text="{Binding TotalXpText}" FontAttributes="Bold" />
                                                <Label Text="{Binding EstimatedStaminaText}" TextColor="{StaticResource CardMutedText}" />
                                                <Button Text="Add pack"
                                                        Command="{Binding Source={x:Reference CreateGoalRoot}, Path=BindingContext.AddQuickPackCommand}"
                                                        CommandParameter="{Binding .}" />
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>