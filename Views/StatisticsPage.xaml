<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Soulbound.Models"
             xmlns:vm="clr-namespace:Soulbound.ViewModels"
             x:Class="Soulbound.Views.StatisticsPage"
             Title="Statistics">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A1A14" Offset="0.0" />
                <GradientStop Color="#5A2A1D" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="12">
                <Label Text="Soulbound analytics" FontSize="28" FontAttributes="Bold" />
                <Label Text="All-time stamina and timelines. Weekly effort lives on Main room."
                       TextColor="{StaticResource CardMutedText}" />

                <Frame Padding="14" BackgroundColor="#6A3422">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Active goals" FontAttributes="Bold" FontSize="18" />
                        <Label Text="Where you stand toward each deadline." FontSize="12" TextColor="{StaticResource CardMutedText}" />
                        <CollectionView ItemsSource="{Binding ActiveGoalStats}" SelectionMode="None" MaximumHeightRequest="280">
                            <CollectionView.EmptyView>
                                <Label Text="No active goals" TextColor="{StaticResource CardMutedText}" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ActiveGoalStatItem">
                                    <Frame Padding="12" Margin="0,0,0,8" BackgroundColor="#5A3218">
                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" />
                                            <Label Text="{Binding DeadlineText, StringFormat='Deadline: {0}'}" FontSize="12" TextColor="{StaticResource CardMutedText}" />
                                            <Label Text="{Binding CategoriesText, StringFormat='Categories: {0}'}" FontSize="12" TextColor="{StaticResource CardMutedText}" />
                                            <ProgressBar Progress="{Binding TimelineProgress}" ScaleY="3" ProgressColor="{StaticResource SuccessAccent}" />
                                            <Label Text="{Binding ProgressPercentText}" FontSize="11" TextColor="{StaticResource CardMutedText}" />
                                            <Label Text="{Binding TimelineHint}" FontSize="11" TextColor="{StaticResource CardMutedText}" />
                                        </VerticalStackLayout>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="14" BackgroundColor="#6A3422">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Stamina by zone (all time)" FontAttributes="Bold" FontSize="18" />
                        <CollectionView ItemsSource="{Binding CategorySummaries}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:CategorySummaryItem">
                                    <Grid ColumnDefinitions="120,*,Auto" ColumnSpacing="8" Padding="0,6">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding CategoryName}" FontAttributes="Bold" />
                                            <Label Text="{Binding MetricsLine}" FontSize="10" TextColor="#D0C8C4" />
                                        </VerticalStackLayout>
                                        <Grid Grid.Column="1" HeightRequest="16" BackgroundColor="#3D2218" VerticalOptions="Center">
                                            <BoxView Color="{Binding BarColorHex}" WidthRequest="{Binding BarWidth}" HorizontalOptions="Start" VerticalOptions="Fill" />
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <Label Text="Activity timeline" FontAttributes="Bold" FontSize="20" />
                <CollectionView ItemsSource="{Binding HistoryRecords}">
                    <CollectionView.EmptyView>
                        <Label Text="No history yet" TextColor="{StaticResource CardMutedText}" HorizontalOptions="Center"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:HistoryRecord">
                            <Frame Padding="12" Margin="0,0,0,8" BackgroundColor="#7A3E28">
                                <Grid ColumnDefinitions="12,*,Auto" ColumnSpacing="10" RowDefinitions="Auto,Auto">
                                    <BoxView Grid.RowSpan="2" Grid.Column="0" WidthRequest="9" Color="{Binding CategoryBarColor}" CornerRadius="5" VerticalOptions="Fill" />
                                    <VerticalStackLayout Grid.Column="1" Grid.RowSpan="2" Spacing="2">
                                        <Label Text="{Binding TaskName}" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding StatusText}" TextColor="{Binding StatusColor}" FontSize="13" FontAttributes="Bold" />
                                        <Label Text="{Binding ResourcesLine}" FontSize="12" TextColor="{StaticResource CardMutedText}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Grid.RowSpan="2"
                                           Text="{Binding DateFinished, StringFormat='{0:dd MMM yyyy HH:mm}'}"
                                           TextColor="{StaticResource CardMutedText}"
                                           FontSize="11"
                                           HorizontalTextAlignment="End"
                                           VerticalTextAlignment="Center" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
