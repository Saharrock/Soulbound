<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Soulbound.Views.GoalHistoryPage"
             xmlns:models="clr-namespace:Soulbound.Models"
             xmlns:converters="clr-namespace:Soulbound.Converters"
             x:Name="GoalHistoryRoot"
             Title="Goal history">
    <ContentPage.Resources>
        <converters:GoalPhotoPathConverter x:Key="GoalPhotoPathConverter" />
    </ContentPage.Resources>
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource AppBackgroundTop}" Offset="0.0" />
                <GradientStop Color="{StaticResource AppBackgroundBottom}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>
        <ScrollView>
            <VerticalStackLayout Spacing="16" Padding="12">
                <Label Text="Active Goals" TextColor="Green" FontSize="24" FontAttributes="Bold"/>
                <CollectionView ItemsSource="{Binding ActiveGoals}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Goal">
                            <Frame Padding="10">
                                <VerticalStackLayout Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" />
                                        <Label Grid.Column="1" Text="{Binding EndDate, StringFormat='Due: {0:dd/MM}'}" TextColor="{StaticResource CardMutedText}"/>
                                    </Grid>
                                    <Label Text="{Binding Description}" TextColor="{StaticResource CardMutedText}" LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding CreatedAt, StringFormat='Created: {0:dd/MM/yyyy}'}" TextColor="{StaticResource CardMutedText}" FontSize="12"/>
                                    <Label Text="{Binding EndDate, StringFormat='Deadline: {0:dd/MM/yyyy}'}" TextColor="{StaticResource CardMutedText}" FontSize="12"/>
                                    <Label Text="{Binding ScheduleText}" TextColor="{StaticResource CardMutedText}" FontSize="12"/>
                                    <Label Text="{Binding ScheduleAdherenceLine}" FontSize="12" TextColor="{StaticResource CardMutedText}"/>
                                    <Label Text="{Binding WorkoutStatsText}" FontSize="12" TextColor="{StaticResource CardMutedText}"/>
                                    <Label Text="{Binding MissedStatsText}" FontSize="12" TextColor="{StaticResource CardMutedText}"/>
                                    <Label Text="{Binding ResolvedStaminaCost, StringFormat='Stamina (workout + Done): {0}'}" FontSize="12" TextColor="{StaticResource CardMutedText}"/>

                                    <Label Text="Photos" FontSize="12" TextColor="{StaticResource CardMutedText}"/>
                                    <VerticalStackLayout Spacing="6">
                                        <Button Text="Add photo"
                                                Padding="8,4"
                                                Command="{Binding Source={x:Reference GoalHistoryRoot}, Path=BindingContext.AddGoalPhotoCommand}"
                                                CommandParameter="{Binding .}" />
                                        <CollectionView ItemsSource="{Binding AttachedPhotos}"
                                                        HeightRequest="72"
                                                        HorizontalScrollBarVisibility="Never">
                                            <CollectionView.ItemsLayout>
                                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6" />
                                            </CollectionView.ItemsLayout>
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate x:DataType="models:GoalPhotoRef">
                                                    <Grid WidthRequest="64" HeightRequest="64">
                                                        <Image Aspect="AspectFill"
                                                               HeightRequest="64"
                                                               WidthRequest="64"
                                                               Source="{Binding RelativePath, Converter={StaticResource GoalPhotoPathConverter}}" />
                                                        <Button Text="×"
                                                                FontSize="10"
                                                                Padding="0"
                                                                HeightRequest="18"
                                                                WidthRequest="18"
                                                                MinimumHeightRequest="18"
                                                                MinimumWidthRequest="18"
                                                                HorizontalOptions="End"
                                                                VerticalOptions="Start"
                                                                Margin="2"
                                                                CornerRadius="9"
                                                                BackgroundColor="#99000000"
                                                                TextColor="White"
                                                                Command="{Binding Source={x:Reference GoalHistoryRoot}, Path=BindingContext.RemoveGoalPhotoCommand}"
                                                                CommandParameter="{Binding .}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>

                                    <FlexLayout Direction="Row" Wrap="Wrap" JustifyContent="End">
                                        <Button Text="Remove"
                                                BackgroundColor="{StaticResource DangerAccent}"
                                                Command="{Binding Source={x:Reference GoalHistoryRoot}, Path=BindingContext.DeleteGoalCommand}"
                                                CommandParameter="{Binding .}" />
                                        <Button Text="Done"
                                                BackgroundColor="{StaticResource SuccessAccent}"
                                                Command="{Binding Source={x:Reference GoalHistoryRoot}, Path=BindingContext.CompleteGoalCommand}"
                                                CommandParameter="{Binding .}" />
                                    </FlexLayout>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Finished Goals" TextColor="Red" FontSize="24" FontAttributes="Bold"/>
                <CollectionView ItemsSource="{Binding FinishedGoals}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Goal">
                            <Frame Padding="10">
                                <VerticalStackLayout Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" />
                                        <Label Grid.Column="1" Text="{Binding EndDate, StringFormat='Done: {0:dd/MM}'}" TextColor="{StaticResource CardMutedText}"/>
                                    </Grid>
                                    <Label Text="{Binding Description}" TextColor="{StaticResource CardMutedText}" LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding CreatedAt, StringFormat='Created: {0:dd/MM/yyyy}'}" TextColor="{StaticResource CardMutedText}" FontSize="12"/>
                                    <Label Text="{Binding EndDate, StringFormat='Finished: {0:dd/MM/yyyy}'}" TextColor="{StaticResource CardMutedText}" FontSize="12"/>
                                    <Label Text="{Binding FinalStatusText, StringFormat='Status: {0}'}" TextColor="{StaticResource CardMutedText}" FontSize="12"/>
                                    <Label Text="{Binding ScheduleAdherenceLine}" FontSize="12" TextColor="{StaticResource CardMutedText}"/>
                                    <Label Text="{Binding WorkoutStatsText}" TextColor="{StaticResource CardMutedText}" FontSize="12"/>
                                    <Label Text="Photos" FontSize="12" TextColor="{StaticResource CardMutedText}"/>
                                    <CollectionView ItemsSource="{Binding AttachedPhotos}"
                                                    HeightRequest="72"
                                                    HorizontalScrollBarVisibility="Never">
                                        <CollectionView.ItemsLayout>
                                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6" />
                                        </CollectionView.ItemsLayout>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:GoalPhotoRef">
                                                <Image Aspect="AspectFill"
                                                       HeightRequest="64"
                                                       WidthRequest="64"
                                                       Source="{Binding RelativePath, Converter={StaticResource GoalPhotoPathConverter}}" />
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
