<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Soulbound.Views.RegistrationPage"
             Title="RegistrationPage">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource AppBackgroundTop}" Offset="0.0" />
                <GradientStop Color="{StaticResource AppBackgroundBottom}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <VerticalStackLayout Padding="24" Spacing="12" VerticalOptions="Center" HorizontalOptions="Center">
            <Button Text="Back to Log In"
                    Command="{Binding GoToLoginCommand}"
                    HorizontalOptions="End" />
            <Frame Padding="20" MaximumWidthRequest="560" HorizontalOptions="Center">
                <VerticalStackLayout Spacing="10">
                    <Label Text="REGISTRATION" FontSize="30" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding MessageForUser}" HorizontalTextAlignment="Center" TextColor="{StaticResource CardMutedText}" />

                    <Label Text="Username" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0" Text="{Binding Username}" Placeholder="Enter your username..." />
                        <Button Grid.Column="1" Text="✕" WidthRequest="36" HeightRequest="36" CornerRadius="18" Padding="0" Command="{Binding ResetUsernameCommand}" />
                    </Grid>
                    <Label Text="{Binding FieldMessages[Username]}" TextColor="#FFD2D2" FontSize="13" />

                    <Label Text="Email" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0" Text="{Binding Email}" Placeholder="Enter your email..." />
                        <Button Grid.Column="1" Text="✕" WidthRequest="36" HeightRequest="36" CornerRadius="18" Padding="0" Command="{Binding ResetEmailCommand}" />
                    </Grid>
                    <Label Text="{Binding FieldMessages[Email]}" TextColor="#FFD2D2" FontSize="13" />

                    <Label Text="Password" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0" Text="{Binding Password}" Placeholder="Enter your password..." IsPassword="True" />
                        <Button Grid.Column="1" Text="✕" WidthRequest="36" HeightRequest="36" CornerRadius="18" Padding="0" Command="{Binding ResetPasswordCommand}" />
                    </Grid>
                    <Label Text="{Binding FieldMessages[Password]}" TextColor="#FFD2D2" FontSize="13" />

                    <Label Text="Confirm password" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0" Text="{Binding ConfirmPassword}" Placeholder="Repeat your password..." IsPassword="True" />
                        <Button Grid.Column="1" Text="✕" WidthRequest="36" HeightRequest="36" CornerRadius="18" Padding="0" Command="{Binding ResetConfirmPasswordCommand}" />
                    </Grid>
                    <Label Text="{Binding FieldMessages[ConfirmPassword]}" TextColor="#FFD2D2" FontSize="13" />

                    <Button Text="Register" Command="{Binding RegisterCommand}" Margin="0,8,0,0" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </Grid>

</ContentPage>