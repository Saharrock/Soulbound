<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Soulbound.Models"
             x:Class="Soulbound.Views.MainRoomPage"
             x:Name="MainRoomRoot"
             Title="Main room">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="?" Command="{Binding OpenHandbookCommand}" Order="Primary" Priority="0" />
    </ContentPage.ToolbarItems>
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource AppBackgroundTop}" Offset="0.0" />
                <GradientStop Color="{StaticResource AppBackgroundBottom}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Padding="20" ColumnDefinitions="1.2*,1*" ColumnSpacing="16">
            <VerticalStackLayout Grid.Column="0" Spacing="12">
                <Label Text="SOULBOUND" FontSize="42" FontAttributes="Bold" />
                <Frame Padding="18">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Main room" FontSize="24" FontAttributes="Bold" />
                        <Label Text="Active goals" TextColor="{StaticResource CardMutedText}" />
                        <Label Text="{Binding ActiveGoalsCount}" FontSize="38" FontAttributes="Bold" />
                        <Label Text="{Binding AverageScheduleSummary}" FontSize="13" TextColor="{StaticResource CardMutedText}" />
                        <Label Text="Nearest deadline" TextColor="{StaticResource CardMutedText}" />
                        <Label Text="{Binding NearestDeadlineText}" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="14">
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Goals for today" FontAttributes="Bold" FontSize="18" />
                            <Button Grid.Column="1" Text="All goals"
                                    Padding="12,6"
                                    Command="{Binding NavigateToGoalHistoryCommand}" />
                        </Grid>
                        <CollectionView ItemsSource="{Binding TodayGoals}" HeightRequest="320">
                            <CollectionView.EmptyView>
                                <Label Text="No workouts queued for today" TextColor="{StaticResource CardMutedText}" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Goal">
                                    <Frame Padding="10" Margin="0,0,0,8" BackgroundColor="{StaticResource CardBackgroundDark}">
                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" />
                                            <Label Text="{Binding ScheduleAdherenceLine}" FontSize="11" TextColor="{StaticResource CardMutedText}" />
                                            <Label Text="{Binding EndDate, StringFormat='Deadline: {0:dd/MM/yyyy}'}" FontSize="12" TextColor="{StaticResource CardMutedText}" />
                                            <Label Text="{Binding ResolvedStaminaCost, StringFormat='Stamina (workout + Done): {0}'}" FontSize="12" TextColor="{StaticResource CardMutedText}" />
                                            <Button Text="Mark workout"
                                                    HorizontalOptions="Start"
                                                    BackgroundColor="{StaticResource SuccessAccent}"
                                                    Command="{Binding Source={x:Reference MainRoomRoot}, Path=BindingContext.MarkWorkoutCommand}"
                                                    CommandParameter="{Binding .}" />
                                        </VerticalStackLayout>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

            <Frame Grid.Column="1" Padding="14">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateToStatisticsCommand}" />
                </Frame.GestureRecognizers>
                <VerticalStackLayout Spacing="10">
                    <Label Text="SoulMate" HorizontalOptions="Center" FontAttributes="Bold" FontSize="20" />
                    <Frame Padding="8" BackgroundColor="{StaticResource CardBackgroundDark}">
                        <Image Source="{Binding PetAvatar}" Aspect="AspectFit" HeightRequest="220" />
                    </Frame>
                    <Label Text="{Binding PetName}" HorizontalOptions="Center" FontSize="24" FontAttributes="Bold" />

                    <Label Text="Weekly stamina · refresh Sundays 00:00"
                           FontSize="11"
                           TextColor="{StaticResource CardMutedText}" />
                    <ProgressBar Progress="{Binding StaminaProgress}" ScaleY="4" ProgressColor="{StaticResource SuccessAccent}" />
                    <Label Text="{Binding StaminaText}" HorizontalOptions="End" TextColor="{StaticResource CardMutedText}" />

                    <Label Text="{Binding PetSummaryLine}"
                           HorizontalOptions="Center"
                           Margin="0,12,0,0"
                           FontAttributes="Bold" />
                    <Label Text="Tap this card for Statistics"
                           HorizontalOptions="Center"
                           FontSize="12"
                           TextColor="{StaticResource CardMutedText}" />
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>

</ContentPage>
