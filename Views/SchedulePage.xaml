<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Soulbound.Models"
             x:Class="Soulbound.Views.SchedulePage"
             Title="Schedule"
             BackgroundColor="#6c2d2c">

    <ScrollView>
        <VerticalStackLayout Padding="12" Spacing="10">
            <Label Text="Weekly schedule"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="White"/>

            <CollectionView ItemsSource="{Binding Goals}">
                <CollectionView.EmptyView>
                    <Label Text="No active goals"
                           TextColor="#f5d2b8"/>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Goal">
                        <Frame BackgroundColor="#9f4636"
                               BorderColor="#42313a"
                               CornerRadius="14"
                               HasShadow="False"
                               Padding="10">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       TextColor="White"/>
                                <Label Text="{Binding ScheduleText}"
                                       TextColor="#f5d2b8"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
